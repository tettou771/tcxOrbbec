# =============================================================================
# TrussC addon .gitignore
# =============================================================================
# Based on the standard TrussC *project* .gitignore. Note the CMakeLists.txt
# asymmetry:
#   - the addon's OWN root CMakeLists.txt (custom build, FetchContent etc.) is
#     HAND-WRITTEN and COMMITTED, so it is intentionally absent from this list.
#   - example CMakeLists.txt stubs are GENERATED by `trusscli update`, so they
#     are ignored (not committed), like CMakePresets.json / .trussc.

# --- Generated build config (regenerated by `trusscli update`) ---------------
CMakePresets.json
.trussc
example*/CMakeLists.txt

# --- Build directories & artifacts -------------------------------------------
build/
build-*/
emscripten/
xcode*/
vs/
*.dSYM/
compile_commands.json
.tc_hot_reload_state

# Generated, OS-dependent build/run scripts
build-web.*

# Orbbec SDK runtime logs (written next to the running binary at startup)
Log/
example*/Log/

# FetchContent / downloaded deps (only when a root CMakeLists.txt fetches them)
libs/

# --- Binary output: ignore bin/, but KEEP bin/data/ (real assets) ------------
# Each example writes its app/exe to bin/; data/ holds committed assets.
example*/bin/*
!example*/bin/data/
# Cover a bin/ at the addon root too, just in case.
/bin/*
!/bin/data/

# --- IDE / editor ------------------------------------------------------------
.vscode/
.vs/
.idea/
.cache/
.clangd/
.ccls-cache/

# --- OS ----------------------------------------------------------------------
.DS_Store
Thumbs.db

# --- Secrets — never commit these (defensive; harmless if unused) ------------
.env
.env.*
secrets.json
secrets.*
*.local

# --- AI assistant scratch / auto-generated instructions ----------------------
# Ignored by default. Delete a line if you deliberately commit a curated file.
CLAUDE.md
GEMINI.md
.cursor/
.cursorrules
.aider*
.claude/
.gemini/
.github/copilot-instructions.md
